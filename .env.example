# Minds Gateway Configuration
# Copy this to .env and fill in the values. 
# DO NOT commit the actual .env file to version control.

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_GROUP_CHAT_ID=your_group_chat_id_here

# Security
X_API_KEY=v-minds-secure-key-2026

# GCP Configuration (Optional if running on GCP VM/Cloud Run)
GOOGLE_CLOUD_PROJECT=animoca-brands-finance
